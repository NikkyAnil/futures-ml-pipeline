"""
MODULE 3 — TESTING & PREDICTION
=================================
Prompt used:
  "Use the trained classification model to predict on test data.
   Return predicted labels, predicted probabilities (for ROC curve),
   and the true binary labels derived from y_test."

Input : model, scaler, X_test, y_test
Output: y_true_binary, y_pred_labels, y_pred_proba
"""

import numpy as np


def run_testing(model, scaler, X_test: np.ndarray, y_test: np.ndarray):
    y_true = np.where(y_test > 0, 1, -1)

    X_scaled = scaler.transform(X_test)
    y_pred   = model.predict(X_scaled)

    # Probability of the positive class (for ROC)
    if hasattr(model, "predict_proba"):
        classes = list(model.classes_)
        pos_idx = classes.index(1) if 1 in classes else 0
        y_proba = model.predict_proba(X_scaled)[:, pos_idx]
    else:
        y_proba = y_pred.astype(float)

    return y_true, y_pred, y_proba
